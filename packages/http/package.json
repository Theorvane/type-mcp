{
  "name": "@type-mcp/http",
  "version": "0.1.0",
  "description": "Fetch Streamable HTTP adapter for type-mcp",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@type-mcp/core": "file:../core"
  }
}
