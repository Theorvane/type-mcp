{
  "name": "type-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Decorator-first TypeScript framework for Model Context Protocol servers",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.base.json && npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "build": "npm run build --workspaces --if-present",
    "verify:packages": "node scripts/verify-package-exports.mjs",
    "verify:publish": "npm run build && node scripts/verify-publish-readiness.mjs",
    "clean": "rimraf packages/*/dist packages/*/coverage coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.5",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
